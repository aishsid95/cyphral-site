---
import Layout from "../layouts/Layout.astro";
import Wordmark from "../components/Wordmark.astro";
import FoundingClientBanner from "../components/FoundingClientBanner.astro";
import PriceBlock from "../components/PriceBlock.astro";
---

<Layout
  title="Cybersecurity & automation for UK SMEs"
  description="Cyphral helps UK small businesses prepare for Cyber Essentials certification, automate operations, and stay secure. Coming soon."
>
  <section class="py-12 md:py-20 text-center">
    <Wordmark size="hero" as="h1" />
    <p class="mt-8 text-lg md:text-xl text-neutral-700 max-w-md mx-auto leading-relaxed">
      Cybersecurity and automation consultancy for UK small businesses. Coming soon.
    </p>
  </section>

  <section class="pb-16 md:pb-24">
    <FoundingClientBanner variant="hero" />
  </section>

  <section class="pb-16 md:pb-24">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      <PriceBlock
        serviceKey="ceReadinessSprint"
        title="Cyber Essentials Readiness Sprint"
        description="Two-week intensive preparation for the Cyber Essentials assessment. We scope your environment, analyse the gaps, guide you through remediation, and prepare a clear submission report."
        showIasmeDisclosure={true}
      />
      <PriceBlock
        serviceKey="automationWorkflow"
        title="Automation & integration"
        description="We build one-off automations to take repetitive work off your plate. Manual tasks you keep doing, tools that need syncing, weekly reports you'd rather not assemble by hand."
      />
    </div>
  </section>
</Layout>
