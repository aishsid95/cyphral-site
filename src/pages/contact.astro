---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Start a conversation with Cyphral. Tell me about your business and what you need, and I will reply within one working day."
>

  <!-- HERO -->
  <section class="mx-auto max-w-[1600px] px-6 md:px-12 lg:px-16 pt-16 md:pt-28 pb-12 md:pb-16">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-medium tracking-[0.18em] uppercase text-maroon-700">
        Contact
      </p>
      <h1 class="mt-6 font-display text-4xl md:text-6xl lg:text-7xl font-semibold text-navy-900 leading-[1.05] tracking-tight">
        Start a conversation.
      </h1>
      <p class="mt-8 text-base md:text-lg text-neutral-800 leading-relaxed">
        Tell me a little about your business and what you need, and I will reply within one working day.
      </p>
    </div>
  </section>

  <!-- CONTACT FORM -->
  <section class="mx-auto max-w-[1600px] px-6 md:px-12 lg:px-16 pb-16 md:pb-24">
    <div class="max-w-2xl mx-auto">
      <form id="contact-form" class="space-y-6" novalidate>

        <!-- Name -->
        <div>
          <label for="name" class="block text-sm font-medium text-navy-900 mb-2">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-md border border-navy-300 bg-white px-4 py-3 text-base text-neutral-900 placeholder-neutral-400 focus:border-maroon-500 focus:outline-none focus:ring-2 focus:ring-maroon-500/30 transition-colors"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="block text-sm font-medium text-navy-900 mb-2">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-md border border-navy-300 bg-white px-4 py-3 text-base text-neutral-900 placeholder-neutral-400 focus:border-maroon-500 focus:outline-none focus:ring-2 focus:ring-maroon-500/30 transition-colors"
          />
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-sm font-medium text-navy-900 mb-2">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            class="w-full rounded-md border border-navy-300 bg-white px-4 py-3 text-base text-neutral-900 placeholder-neutral-400 focus:border-maroon-500 focus:outline-none focus:ring-2 focus:ring-maroon-500/30 transition-colors"
          ></textarea>
        </div>

        <!-- Honeypot: hidden from humans, tempting to bots. Do not fill this in. -->
        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="company">Company</label>
          <input
            type="text"
            id="company"
            name="company"
            tabindex="-1"
            autocomplete="off"
          />
        </div>

        <!-- Submit. Live: posts to /api/contact via the fetch handler below. -->
        <div>
          <button
            id="contact-submit"
            type="submit"
            class="inline-flex items-center justify-center rounded-md bg-navy-900 hover:bg-navy-700 text-white px-6 py-3 text-base font-medium transition-colors"
          >
            Send message
          </button>
          <p class="mt-3 text-sm text-neutral-600">
            For now, please email
            <a
              href="mailto:hello@cyphral.co.uk"
              class="text-maroon-700 hover:text-maroon-500 underline underline-offset-4 decoration-neutral-300 hover:decoration-maroon-500 transition-colors"
            >
              hello@cyphral.co.uk
            </a>
            directly.
          </p>
        </div>

        <!-- Status message, populated by the form script on submit. -->
        <p
          id="contact-status"
          role="status"
          aria-live="polite"
          class="hidden text-base leading-relaxed"
        ></p>
      </form>
    </div>
  </section>

  <!--
    Form submission handling. Astro processes (does not inline) this <script>,
    bundling it to an external module file, so it is CSP-safe (no inline JS).
    Progressive enhancement: it intercepts submit, POSTs JSON to /api/contact,
    and shows a success or error message. While the submit button is disabled
    the listener simply never fires; enabling the button activates it.
  -->
  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const statusEl = document.getElementById('contact-status');
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

    if (form && statusEl && submitBtn) {
      const show = (message: string, ok: boolean) => {
        statusEl.textContent = message;
        statusEl.classList.remove('hidden', 'text-maroon-700', 'text-navy-900');
        statusEl.classList.add(ok ? 'text-navy-900' : 'text-maroon-700');
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const data = new FormData(form);
        const payload = {
          name: String(data.get('name') ?? ''),
          email: String(data.get('email') ?? ''),
          message: String(data.get('message') ?? ''),
          company: String(data.get('company') ?? ''), // honeypot
        };

        const originalLabel = submitBtn.textContent;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (res.ok) {
            form.reset();
            show('Thank you. Your message has been sent and I will reply within one working day.', true);
            submitBtn.textContent = 'Sent';
            return; // leave the button disabled after a successful send
          }

          let message = 'Sorry, something went wrong. Please email hello@cyphral.co.uk directly.';
          try {
            const body = (await res.json()) as { error?: string };
            if (body.error) message = body.error;
          } catch {
            // keep the default message
          }
          show(message, false);
        } catch {
          show('Sorry, the message could not be sent. Please email hello@cyphral.co.uk directly.', false);
        }

        // Re-enable so the visitor can correct and retry (only on failure).
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      });
    }
  </script>

</Layout>
