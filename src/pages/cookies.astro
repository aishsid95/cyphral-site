---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Cookie Policy"
  description="Cyphral sets no cookies. We use no third-party cookies, tracking pixels, or behavioural advertising, and our analytics is cookieless."
>

  <!-- HERO -->
  <section class="mx-auto max-w-[1600px] px-6 md:px-12 lg:px-16 pt-4 md:pt-8 pb-8 md:pb-12">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-medium tracking-[0.18em] uppercase text-maroon-700">
        Cookies
      </p>
      <h1 class="mt-6 font-display text-4xl md:text-6xl lg:text-7xl font-semibold text-navy-900 leading-[1.05] tracking-tight">
        Cookie Policy
      </h1>
      <p class="mt-6 text-sm text-neutral-600">
        Last updated: 22 June 2026
      </p>
    </div>
  </section>

  <!-- BODY -->
  <section class="mx-auto max-w-[1600px] px-6 md:px-12 lg:px-16 pb-16 md:pb-24">
    <div class="max-w-5xl mx-auto text-base md:text-lg text-neutral-800 leading-relaxed">

      <p class="text-justify hyphens-auto">
        This website does not use cookies. We set no cookies of our own and use no third-party cookies, tracking pixels, or behavioural advertising.
      </p>
      <p class="mt-4 text-justify hyphens-auto">
        Our analytics provider, Cloudflare Web Analytics, is privacy-first and cookieless. It does not use cookies, does not fingerprint visitors, and does not track people across sites.
      </p>
      <p class="mt-4 text-justify hyphens-auto">
        Because we set no cookies, there is no cookie banner and nothing for you to accept or decline.
      </p>
      <p class="mt-4 text-justify hyphens-auto">
        If this ever changes, we will update this page and introduce appropriate controls before any cookie is set.
      </p>

    </div>
  </section>

</Layout>
