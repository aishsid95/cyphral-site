---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date);
---

<Layout
  title="Insights"
  description="Plain-language analysis of UK cyber security, Cyber Essentials, and what it means for small businesses."
>
  <section class="mx-auto max-w-[1600px] px-6 md:px-12 lg:px-16 py-16 md:py-24">
    <header class="max-w-2xl mb-16">
      <p class="text-xs font-medium tracking-[0.18em] uppercase text-maroon-700">
        Insights
      </p>
      <h1 class="mt-4 font-display text-4xl md:text-6xl font-semibold text-navy-900 leading-tight tracking-tight">
        Notes from the readiness side of UK cyber.
      </h1>
      <p class="mt-6 text-base md:text-lg text-neutral-700 leading-relaxed max-w-xl">
        Plain-language analysis of UK cyber security policy, Cyber Essentials, and what the changing landscape means for small businesses trying to focus on running the business.
      </p>
    </header>

    <ul class="space-y-12 max-w-3xl">
      {posts.map((post) => (
        <li>
          <a
            href={`/insights/${post.id}`}
            class="group block border-t border-neutral-200 pt-8 hover:border-maroon-300 transition-colors"
          >
            <p class="text-xs text-neutral-600">
              {formatDate(post.data.pubDate)} · {post.data.readingTime}
            </p>
            <h2 class="mt-3 font-display text-2xl md:text-3xl font-semibold text-navy-900 group-hover:text-maroon-700 transition-colors leading-tight">
              {post.data.title}
            </h2>
            <p class="mt-3 text-base text-neutral-700 leading-relaxed">
              {post.data.description}
            </p>
            <p class="mt-4 text-sm text-maroon-700 group-hover:text-maroon-500">
              Read →
            </p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
