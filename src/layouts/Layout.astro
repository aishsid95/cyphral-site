---
/**
 * Cyphral base layout.
 *
 * Every page imports and wraps its content in this Layout. It owns:
 *   - <head>: charset, viewport, title, meta description, canonical, OG tags, favicon
 *   - Skip-to-content link (a11y requirement)
 *   - Sticky header with scroll-aware background
 *   - Main content slot (constrained to max-w-6xl)
 *   - Footer with brand, contact, legal links
 *
 * Props:
 *   - title: page title (will be appended with " — Cyphral" unless suppressTitleSuffix is true)
 *   - description: meta description (~140-160 chars)
 *   - canonical: full URL of the canonical version of this page (defaults to current URL)
 *   - suppressTitleSuffix: rare cases (homepage where suffix is awkward) — default false
 */
import Wordmark from "../components/Wordmark.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  suppressTitleSuffix?: boolean;
}

const {
  title,
  description,
  canonical,
  suppressTitleSuffix = false,
} = Astro.props;

const fullTitle = suppressTitleSuffix ? title : `${title} — Cyphral`;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site ?? "https://cyphral.co.uk").toString();
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Cyphral" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Theme colour for mobile chrome -->
    <meta name="theme-color" content="#FAFAF7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0B1B2B" media="(prefers-color-scheme: dark)" />

    <!-- Preload the most-used font weight to avoid FOUT on the wordmark -->
    <link
      rel="preload"
      href="/fonts/switzer-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Robots: indexable, no special directives -->
    <meta name="robots" content="index, follow" />
  </head>

  <body class="bg-neutral-50 text-neutral-900 font-display antialiased">
    <!-- Skip to content (a11y): visible only when focused -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-navy-500 focus:text-neutral-50 focus:px-4 focus:py-2 focus:rounded-md focus:outline-none focus:shadow-lg"
    >
      Skip to content
    </a>

    <!-- Sticky header. Background is transparent at top of page and fades in as user scrolls. -->
    <header
      id="site-header"
      class="sticky top-0 z-40 transition-colors duration-200"
      data-scrolled="false"
    >
      <div class="mx-auto max-w-6xl px-6 md:px-8 py-5 flex items-center justify-between">
        <a
          href="/"
          aria-label="Cyphral home"
          class="inline-flex items-center"
        >
          <Wordmark size="md" />
        </a>

        <nav aria-label="Primary" class="flex items-center gap-6 md:gap-8 text-base">
          <a href="/services" class="text-neutral-700 hover:text-navy-500 transition-colors">Services</a>
          <a href="/about" class="text-neutral-700 hover:text-navy-500 transition-colors">About</a>
          <a href="/insights" class="text-neutral-700 hover:text-navy-500 transition-colors hidden md:inline-block">Insights</a>
          <a
            href="/contact"
            class="inline-flex items-center px-4 py-1.5 leading-none rounded-md bg-navy-500 text-neutral-50 hover:bg-navy-600 transition-colors text-sm md:text-base"
          >
            Contact
          </a>
        </nav>
      </div>

      <!-- Subtle border that appears when scrolled (controlled via data-scrolled CSS below) -->
      <div class="header-border h-px bg-neutral-200/0 transition-colors duration-200"></div>
    </header>

    <!-- Main content -->
    <main id="main" class="mx-auto max-w-6xl px-6 md:px-8 py-12 md:py-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-neutral-200 mt-24 md:mt-32">
      <div class="mx-auto max-w-6xl px-6 md:px-8 py-12 md:py-16">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 md:gap-16">

          <div class="space-y-4 md:max-w-sm">
            <Wordmark size="sm" />
            <p class="text-sm text-neutral-600 leading-relaxed">
              Cybersecurity and automation consultancy for UK small businesses. We help you prepare for Cyber Essentials, automate operations, and stay secure.
            </p>
            <p class="text-sm">
              <a
                href="mailto:hello@cyphral.co.uk"
                class="text-navy-500 hover:text-maroon-700 transition-colors"
              >
                hello@cyphral.co.uk
              </a>
            </p>
          </div>

          <div class="grid grid-cols-2 gap-8 md:gap-16 text-sm">
            <div>
              <h2 class="text-xs uppercase tracking-wider text-neutral-500 font-semibold mb-3">
                Site
              </h2>
              <ul class="space-y-2">
                <li><a href="/services" class="text-neutral-700 hover:text-navy-500 transition-colors">Services</a></li>
                <li><a href="/about" class="text-neutral-700 hover:text-navy-500 transition-colors">About</a></li>
                <li><a href="/insights" class="text-neutral-700 hover:text-navy-500 transition-colors">Insights</a></li>
                <li><a href="/contact" class="text-neutral-700 hover:text-navy-500 transition-colors">Contact</a></li>
              </ul>
            </div>

            <div>
              <h2 class="text-xs uppercase tracking-wider text-neutral-500 font-semibold mb-3">
                Legal
              </h2>
              <ul class="space-y-2">
                <li><a href="/privacy" class="text-neutral-700 hover:text-navy-500 transition-colors">Privacy</a></li>
                <li><a href="/cookies" class="text-neutral-700 hover:text-navy-500 transition-colors">Cookies</a></li>
                <li><a href="/terms" class="text-neutral-700 hover:text-navy-500 transition-colors">Terms</a></li>
              </ul>
            </div>
          </div>

        </div>

        <div class="mt-10 md:mt-14 pt-8 border-t border-neutral-200 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-neutral-500">
          <p>© {currentYear} Cyphral. Sole trader registered in England.</p>
          <p>Made in London.</p>
        </div>
      </div>
    </footer>

    <!--
      Tiny scroll-aware header script. No framework, no Astro client directive,
      just a plain <script> that runs once on first paint.
      Marks data-scrolled="true" on header when user has scrolled past 8px,
      which CSS uses to fade in the background and bottom border.
    -->
    <script is:inline>
      (function () {
        var header = document.getElementById('site-header');
        if (!header) return;
        var border = header.querySelector('.header-border');
        var threshold = 8;

        function update() {
          var scrolled = window.scrollY > threshold;
          if (scrolled) {
            header.dataset.scrolled = 'true';
            header.classList.add('bg-neutral-50/85', 'backdrop-blur-md');
            if (border) border.classList.add('bg-neutral-200');
          } else {
            header.dataset.scrolled = 'false';
            header.classList.remove('bg-neutral-50/85', 'backdrop-blur-md');
            if (border) border.classList.remove('bg-neutral-200');
          }
        }

        update();
        window.addEventListener('scroll', update, { passive: true });
      })();
    </script>
  </body>
</html>
